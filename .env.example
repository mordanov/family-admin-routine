# family-admin-routine — standalone / dev environment
# Copy to .env and fill in real values.

# App security
SECRET_KEY=change-me-admin-routine-secret

# Users
ADMIN_USER1_USERNAME=admin1
ADMIN_USER1_PASSWORD=change-me-admin1-password
ADMIN_USER2_USERNAME=admin2
ADMIN_USER2_PASSWORD=change-me-admin2-password

# Backup storage directory (inside container)
BACKUPS_DIR=/app/backups

# PostgreSQL host overrides (defaults point to recipes-db in web-folders)
RECIPES_DB_HOST=recipes-db
POETRY_DB_HOST=recipes-db
NEWS_DB_HOST=recipes-db
BUDGET_DB_HOST=recipes-db
REMINDERS_DB_HOST=recipes-db

# --- family-kitchen-recipes ---
RECIPES_POSTGRES_DB=recipes
RECIPES_POSTGRES_USER=recipes_user
RECIPES_POSTGRES_PASSWORD=change-me-recipes-db

# --- poetry-site ---
POETRY_POSTGRES_DB=poetry
POETRY_POSTGRES_USER=poetry_user
POETRY_POSTGRES_PASSWORD=change-me-poetry-db

# --- news-site ---
NEWS_POSTGRES_DB=news
NEWS_POSTGRES_USER=news_user
NEWS_POSTGRES_PASSWORD=change-me-news-db

# --- budget-site ---
BUDGET_POSTGRES_DB=budget
BUDGET_POSTGRES_USER=budget_user
BUDGET_POSTGRES_PASSWORD=change-me-budget-db

# --- reminders-app ---
REMINDERS_POSTGRES_DB=reminders
REMINDERS_POSTGRES_USER=reminders_user
REMINDERS_POSTGRES_PASSWORD=change-me-reminders-db
